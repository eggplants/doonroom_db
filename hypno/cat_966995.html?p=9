      }
    }
  },
  fillinTag: function(select, id) {
    var options = select.getElementsByTagName('option');
    var removableOptions = [];
    for (var i = 0; i < options.length; i++) {
      this.selectedTagIds.forEach(function(value) {
        if (value && id !== value && options[i].value == value) {
          removableOptions.push(options[i]);
