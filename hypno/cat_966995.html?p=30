<article class="article" itemscope itemtype="http://schema.org/BlogPosting">
<!-- 記事ヘッダー、記事タイトル -->
<header class="article-header">
	<p class="article-date"><time datetime="2018-01-10T21:00:40+09:00" itemprop="datePublished">2018年01月10日</time></p>
	<h1 class="article-title" itemprop="name"><a href="http://doonroom.blog.jp/archives/74424206.html" itemprop="url">[Workaholic](社畜催眠)</a></h1>
	
</header>
