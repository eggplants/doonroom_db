<article class="article" itemscope itemtype="http://schema.org/BlogPosting">
<!-- 記事ヘッダー、記事タイトル -->
<header class="article-header">
	<p class="article-date"><time datetime="2014-11-15T21:00:21+09:00" itemprop="datePublished">2014年11月15日</time></p>
	<h1 class="article-title" itemprop="name"><a href="http://doonroom.blog.jp/archives/32142439.html" itemprop="url">bar“HYPNOSE” homme -催眠音声-</a></h1>
	
</header>
