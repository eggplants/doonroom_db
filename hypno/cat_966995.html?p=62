<!-- 記事ヘッダー、記事タイトル -->
<header class="article-header">
	<p class="article-date"><time datetime="2015-06-11T21:00:16+09:00" itemprop="datePublished">2015年06月11日</time></p>
	<h1 class="article-title" itemprop="name"><a href="http://doonroom.blog.jp/archives/32142711.html" itemprop="url">催眠的な彼女6月号</a></h1>
	
</header>
