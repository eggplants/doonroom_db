<!-- 記事ヘッダー、記事タイトル -->
<header class="article-header">
	<p class="article-date"><time datetime="2016-01-11T21:00:45+09:00" itemprop="datePublished">2016年01月11日</time></p>
	<h1 class="article-title" itemprop="name"><a href="http://doonroom.blog.jp/archives/52376894.html" itemprop="url">さいみん13000～深海に潜むもの～</a></h1>
	
</header>
